# --- This subtree is developed inside Plutus but is NOT part of its git history. ---
# It will be `mv`-ed out to its own public repo later (clean-room generalization).
# Plutus' root .gitignore should also exclude sandbox/ so nothing here is committed
# into Plutus by accident.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets / local config — NEVER commit API keys
.env
.env.*
!.env.example

# Telemetry sink output (local JsonlSink / SqliteSink)
*.jsonl
*.sqlite
*.db
# ...but these jsonl are source, not generated output — keep them tracked.
# (no inline comments below: gitignore treats them as part of the pattern)
# regression-gate input (CI reads this):
!eval_runs.jsonl
# eval golden sets:
!src/genai_prod_kit/evals/golden/*.jsonl

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db
